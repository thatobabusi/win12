{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "vitest/globals": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "vitest"
  ],
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "no-console": [
      "warn",
      {
        "allow": ["warn", "error", "log"]
      }
    ],
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": ["error", "always"],
    "curly": "error"
  },
  "overrides": [
    {
      "files": ["tests/**/*.{js,test.js,spec.js}"],
      "env": {
        "vitest/globals": true
      }
    }
  ]
}
