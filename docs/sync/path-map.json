{
  "description": "Maps REFERENCE project (Tools/win12-git, flat layout) paths to this WIP project (public/ + src/styles/assets layout). Used by compare.mjs. A rule whose 'ref' ends with '/' is a directory subtree; otherwise it is a single file. Add rules here when upstream introduces new top-level files/dirs that the comparison reports as UNMAPPED.",
  "ignore": [".git", ".github", ".claude", "node_modules", ".idea", "readme"],
  "rules": [
    { "ref": "desktop.js", "wip": "public/js/desktop.js" },
    { "ref": "sw.js", "wip": "public/sw.js" },
    { "ref": "base.css", "wip": "public/styles/base.css" },
    { "ref": "desktop.css", "wip": "public/styles/desktop.css" },
    { "ref": "bootstrap-icons.css", "wip": "public/styles/bootstrap-icons.css" },
    { "ref": "404.html", "wip": "public/404.html" },
    { "ref": "bios.html", "wip": "public/bios.html" },
    { "ref": "bluescreen.html", "wip": "public/bluescreen.html" },
    { "ref": "boot.html", "wip": "public/boot.html" },
    { "ref": "desktop.html", "wip": "public/desktop.html" },
    { "ref": "index.html", "wip": "public/index.html" },
    { "ref": "mainpage.html", "wip": "public/mainpage.html" },
    { "ref": "reload.html", "wip": "public/reload.html" },
    { "ref": "shutdown.html", "wip": "public/shutdown.html" },
    { "ref": "bg.svg", "wip": "public/assets/images/bg.svg" },
    { "ref": "bg-dark.svg", "wip": "public/assets/images/bg-dark.svg" },
    { "ref": "module/", "wip": "public/js/modules/" },
    { "ref": "scripts/", "wip": "public/scripts/" },
    { "ref": "icon/", "wip": "public/assets/icons/" },
    { "ref": "img/", "wip": "public/assets/images/" },
    { "ref": "fonts/", "wip": "public/assets/fonts/" },
    { "ref": "media/", "wip": "public/assets/media/" },
    { "ref": "data/", "wip": "public/js/data/" },
    { "ref": "games/", "wip": "public/js/games/" },
    { "ref": "apps/", "wip": "public/apps/" },
    { "ref": "lang/", "wip": "public/lang/" },
    { "ref": "pwa/", "wip": "public/pwa/" },
    { "ref": "tauri/", "wip": "public/tauri/" },
    { "ref": "README.md", "wip": "README.md" },
    { "ref": "changelog.md", "wip": "changelog.md" },
    { "ref": "CONTRIBUTING.md", "wip": "CONTRIBUTING.md" },
